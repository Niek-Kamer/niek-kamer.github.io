{
	"name": "portfolio",
	"type": "module",
	"version": "0.0.1",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "bun run codegen && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"prepare": "lefthook install || true",
		"typecheck": "astro check",
		"codegen": "cargo run --release --quiet --manifest-path tokens-gen/Cargo.toml -- src/generated/tokens.ts",
		"codegen:check": "bun run codegen && git diff --exit-code -- src/generated/",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint . && eslint .",
		"lint:fix": "biome lint --write . && eslint --fix .",
		"check": "biome check --write . && eslint --fix .",
		"check:ci": "biome check . && eslint ."
	},
	"dependencies": {
		"@astrojs/mdx": "^5.0.4",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.2",
		"@fontsource-variable/fraunces": "^5.2.9",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource/inter": "^5.2.8",
		"@resvg/resvg-js": "^2.6.2",
		"@vanilla-extract/css": "^1.20.1",
		"@vanilla-extract/sprinkles": "^1.6.5",
		"@vanilla-extract/vite-plugin": "^5.2.2",
		"astro": "^6.3.1",
		"katex": "^0.16.45",
		"rehype-katex": "^7.0.1",
		"remark-math": "^6.0.0",
		"satori": "^0.26.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@biomejs/biome": "^2.4.15",
		"@types/node": "^25.7.0",
		"astro-eslint-parser": "^1.4.0",
		"eslint": "^10.3.0",
		"eslint-plugin-astro": "^1.7.0",
		"lefthook": "^2.1.6",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3"
	}
}
