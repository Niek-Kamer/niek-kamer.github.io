---
/**
 * 65ch centered reading column. Used by index pages (writing, projects,
 * about, 404) where the content is pure prose and a tight reading width
 * is appropriate.
 *
 *   <ProseBand>
 *     <h1>Writing</h1>
 *     <ul>…</ul>
 *   </ProseBand>
 *
 * Pair with `<WideBand>` (85ch) for the article column on writing/projects
 * detail pages.
 */
import type { HTMLAttributes } from 'astro/types';
import { sprinkles } from '../../styles/sprinkles.css';

interface Props extends HTMLAttributes<'div'> {
	as?:
		| 'div'
		| 'section'
		| 'header'
		| 'footer'
		| 'article'
		| 'main'
		| 'aside'
		| 'nav';
}

const { as: Tag = 'div', class: className, ...rest } = Astro.props;

const cls = sprinkles({
	maxWidth: 'prose',
	marginInline: 'auto',
	width: '100%',
});
---

<Tag class:list={[cls, className]} {...rest}>
	<slot />
</Tag>
