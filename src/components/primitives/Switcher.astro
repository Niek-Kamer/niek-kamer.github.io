---
/**
 * Row → column at a threshold. Children share width equally when in a row;
 * they full-width when stacked. Use for "two cards side-by-side, stacked
 * on mobile".
 *
 *   <Switcher at="md" gap="lg">
 *     <Card />
 *     <Card />
 *   </Switcher>
 */
import type { HTMLAttributes } from 'astro/types';
import { sprinkles, type Sprinkles } from '../../styles/sprinkles.css';

type Breakpoint = 'sm' | 'md' | 'lg' | 'xl';

interface Props extends HTMLAttributes<'div'> {
	as?: 'div' | 'section' | 'ul' | 'ol';
	gap?: Sprinkles['gap'];
	at?: Breakpoint;
}

const { as: Tag = 'div', gap = 'md', at = 'md', class: className, ...rest } = Astro.props;

// Use a responsive flexDirection — sprinkles handles the breakpoint condition.
const cls = sprinkles({
	display: 'flex',
	flexDirection: { base: 'column', [at]: 'row' },
	flexWrap: 'wrap',
	gap,
});
---

<Tag class:list={[cls, className]} {...rest}>
	<slot />
</Tag>
