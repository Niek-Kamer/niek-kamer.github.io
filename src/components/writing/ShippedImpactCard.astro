---
/**
 * Short "shipped impact" callout for the top of a writing entry. Surfaces
 * the headline measured number for casual / commercial readers who don't
 * want to scroll through methodology to find the result. Pair with
 * `<ShippedImpactDetail>` further down for the full breakdown.
 */
import Stack from '../primitives/Stack.astro';
import * as styles from './styles/ShippedImpact.css';

interface Props {
	headline: string;
	hardware: string;
	scope?: string;
	detailHref?: string;
}

const { headline, hardware, scope, detailHref } = Astro.props;
---

<aside class={styles.card} aria-label="Shipped impact summary">
	<Stack gap="2xs">
		<span class={styles.eyebrow}>Shipped impact</span>
		<p class={styles.headline}>{headline}</p>
		<p class={styles.hardware}>
			Measured on {hardware}{scope ? ` · ${scope}` : ''}
			{detailHref && (
				<>
					{' · '}<a href={detailHref}>Full breakdown</a>
				</>
			)}
		</p>
	</Stack>
</aside>
