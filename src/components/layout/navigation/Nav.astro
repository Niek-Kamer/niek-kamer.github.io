---
import Cluster from '../../primitives/Cluster.astro';
import { site, type NavLink } from '../../../data/site';
import * as styles from './styles/Nav.css';

interface Props {
	items?: NavLink[];
	label?: string;
	class?: string;
}

const { items = site.nav, label = 'Primary', class: className } = Astro.props;
const path = Astro.url.pathname;
---

<nav aria-label={label} class={className}>
	<Cluster as="ul" gap="md" class={styles.list}>
		{items.map((item) => (
			<li>
				<a
					href={item.href}
					class={styles.link}
					aria-current={path.startsWith(item.href) && item.href !== '/' ? 'page' : undefined}
				>
					{item.label}
				</a>
			</li>
		))}
	</Cluster>
</nav>
