---
/**
 * Site wordmark. Defaults to the configured site name from `data/site.ts` —
 * pass `name` to override (e.g. for a sub-property or a different page).
 */
import { site } from '../../../data/site';
import * as styles from './styles/Brand.css';

interface Props {
	name?: string;
	class?: string;
}

const { name = site.name, class: className } = Astro.props;
---

<a href="/" class:list={[styles.brand, className]} aria-label={`${name} — home`}>
	{name}
</a>
