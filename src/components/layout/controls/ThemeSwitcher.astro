---
import { sprinkles } from '../../../styles/sprinkles.css';
import * as styles from './styles/ThemeSwitcher.css';

const button = sprinkles({
	display: 'inline-flex',
	alignItems: 'center',
	justifyContent: 'center',
	color: 'textMuted',
	backgroundColor: 'bgSubtle',
	borderRadius: 'md',
	borderColor: 'border',
	padding: 'xs',
});
---

<button
	type="button"
	data-theme-toggle
	aria-label="Toggle theme"
	class:list={[button, styles.button]}
>
	<svg
		class:list={[styles.icon, styles.sun]}
		xmlns="http://www.w3.org/2000/svg"
		width="20"
		height="20"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<circle cx="12" cy="12" r="4" />
		<path d="M12 2v2" />
		<path d="M12 20v2" />
		<path d="m4.93 4.93 1.41 1.41" />
		<path d="m17.66 17.66 1.41 1.41" />
		<path d="M2 12h2" />
		<path d="M20 12h2" />
		<path d="m6.34 17.66-1.41 1.41" />
		<path d="m19.07 4.93-1.41 1.41" />
	</svg>
	<svg
		class:list={[styles.icon, styles.moon]}
		xmlns="http://www.w3.org/2000/svg"
		width="20"
		height="20"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
	</svg>
</button>

<script>
	const buttons = document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]');

	function syncAriaLabel(btn: HTMLButtonElement, theme: string) {
		btn.setAttribute(
			'aria-label',
			theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme',
		);
	}

	for (const btn of buttons) {
		syncAriaLabel(btn, document.documentElement.dataset.theme ?? 'light');
		btn.addEventListener('click', () => {
			const current = document.documentElement.dataset.theme ?? 'light';
			const next = current === 'dark' ? 'light' : 'dark';
			document.documentElement.dataset.theme = next;
			try {
				localStorage.setItem('theme', next);
			} catch {
			}
			for (const b of buttons) syncAriaLabel(b, next);
		});
	}
</script>
