---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/primitives/Container.astro';
import ProseBand from '../components/primitives/ProseBand.astro';
import Stack from '../components/primitives/Stack.astro';
import { sprinkles } from '../styles/sprinkles.css';
import { prose } from '../styles/prose.css';
import { site } from '../data/site';

// Single-entry collection: prose lives in `src/content/about/about.mdx`.
const entry = await getEntry('about', 'about');
if (!entry) throw new Error('about entry missing — expected src/content/about/about.mdx');
const { Content } = await render(entry);

const heading = sprinkles({
	fontSize: 'h1',
	fontWeight: 'semibold',
	letterSpacing: 'tight',
	lineHeight: 'tight',
});
const subtitle = sprinkles({ fontSize: 'lg', color: 'textMuted' });
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<Container>
		<ProseBand>
			<Stack as="article" gap="2xl">
				<Stack gap="md">
					<h1 class={heading}>{entry.data.title}</h1>
					<p class={subtitle}>{site.author.location}</p>
				</Stack>

				<div class={prose}>
					<Content />
				</div>
			</Stack>
		</ProseBand>
	</Container>
</BaseLayout>
